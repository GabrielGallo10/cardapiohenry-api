# PostgreSQL — Barber Shop API
# Copie para .env e preencha os valores (o .env não é versionado).
# Se a senha tiver # ou espaços, use aspas: DB_PASSWORD="sua_senha#aqui"

DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=sua_senha
DB_NAME=barbershop
DB_SSLMODE=disable

# JWT — obrigatório em produção
JWT_SECRET=sua-chave-secreta-longa-e-aleatoria-min-32-chars
JWT_EXPIRATION_HOURS=24
# Validade do token após validar o código por e-mail (minutos), usado em POST /password-reset/confirm
PASSWORD_RESET_TOKEN_MINUTES=15

# E-mail transacional (Brevo) — recuperação de senha (POST /password-reset/*)
# Migrações: migrations/001_password_reset_challenges.sql e migrations/002_email_password_reset.sql
# log = só regista o código nos logs do servidor (desenvolvimento)
# brevo = envio real pela API Brevo (https://app.brevo.com) — crie uma chave SMTP/API e confirme o remetente
EMAIL_PROVIDER=log
BREVO_API_KEY=
BREVO_SENDER_EMAIL=
BREVO_SENDER_NAME=HenryBebidas

# CORS — origens permitidas para o frontend (separadas por vírgula).
# Necessário para conexão do frontend com a API.
# Ex.: CORS_ORIGINS=https://seu-dominio.com,http://localhost:3000

# Cloudflare R2 — Upload via backend (multipart -> PutObject)
# Necessário para o endpoint POST /upload:
# - faz upload do arquivo direto no R2
# - retorna uma URL pública para salvar no DB via rotas existentes
#
# Necessário:
CF_R2_ACCOUNT_ID=SEU_ACCOUNT_ID_AQUI
CF_R2_ACCESS_KEY_ID=SEU_ACCESS_KEY_ID_AQUI
CF_R2_SECRET_ACCESS_KEY=SEU_SECRET_ACCESS_KEY_AQUI
CF_R2_BUCKET=SEU_BUCKET_AQUI

# Opcional:
# Para assinatura V4, a região pode ser "auto" (default).
CF_R2_REGION=auto
# Se vazio, o backend monta endpoint: https://<account_id>.r2.cloudflarestorage.com
CF_R2_ENDPOINT=
# URL base pública — após habilitar "Acesso público" / Public development URL no bucket,
# copie a "URL pública do bucket" do painel (R2 > bucket > Configurações) se for diferente
# do default. Sem barra no fim. Ex.: https://henry-bebidas.r2.dev
# Com domínio próprio ligado ao bucket, use esse domínio aqui.
CF_R2_PUBLIC_BASE_URL=
# Expiração do upload_url em minutos (default: 30)
CF_R2_UPLOAD_EXPIRY_MINUTES=30
# Prefixo no object_key (default: uploads)
CF_R2_OBJECT_KEY_PREFIX=uploads
# Se o upload falhar com erro de assinatura/endpoint, tente true (estilo path: .../bucket/key)
CF_R2_USE_PATH_STYLE=false
#
# Imagens: o subdomínio *.r2.dev da Cloudflare pode devolver 500. Por defeito o upload devolve
# links para o proxy público GET /storage/… nesta API (ficheiros continuam no R2).
# Se o Host do pedido de upload não for o domínio público (ex.: rede interna), defina:
# PUBLIC_OBJECT_BASE_URL=https://api.seudominio.com
PUBLIC_OBJECT_BASE_URL=
